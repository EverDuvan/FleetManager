# FleetManager - Variables de entorno de producción
# Copia este archivo a .env y ajusta los valores antes de desplegar

# Puerto en el que escucha el servidor Express
PORT=8080

# Entorno de Node.js
NODE_ENV=production

# Ruta al archivo de base de datos SQLite
# En Docker con volumen persistente, usar /data/database.sqlite
DATABASE_PATH=/data/database.sqlite
